{
    "name": "matheusmarnt/scoutify",
    "description": "⌘K global search modal for Laravel — multi-model Livewire UI powered by Scout",
    "keywords": [
        "laravel",
        "scout",
        "livewire",
        "search"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Matheus Mariano",
            "email": "matheus.marnt@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "algolia/algoliasearch-client-php": "^4.42",
        "blade-ui-kit/blade-heroicons": "^2.5",
        "blade-ui-kit/blade-icons": "^1.6",
        "http-interop/http-factory-guzzle": "^1.2",
        "illuminate/contracts": "^11.0|^12.0",
        "laravel/prompts": "^0.1|^0.3|^1.0",
        "laravel/scout": "^11.1",
        "livewire/livewire": "^3.0|^4.0",
        "meilisearch/meilisearch-php": "^1.16",
        "nikic/php-parser": "^5.0",
        "spatie/laravel-package-tools": "^1.16",
        "typesense/typesense-php": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.0"
    },
    "suggest": {
        "algolia/algoliasearch-client-php": "Algolia driver for Scout",
        "meilisearch/meilisearch-php": "Meilisearch driver for Scout",
        "typesense/typesense-php": "Typesense driver for Scout"
    },
    "autoload": {
        "psr-4": {
            "Matheusmarnt\\Scoutify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Matheusmarnt\\Scoutify\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "test:coverage": "vendor/bin/pest --coverage --min=90",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Matheusmarnt\\Scoutify\\ScoutifyServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
